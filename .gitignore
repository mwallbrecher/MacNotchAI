.DS_Store
.AppleDouble
.LSOverride
._*

# ── Xcode ─────────────────────────────────────────────────────────────────────
# User-specific Xcode settings (window layout, breakpoints, etc.)
xcuserdata/
*.xcuserstate
*.xccheckout
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
